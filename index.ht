<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>RunDiary — チーム練習日誌</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Noto+Sans+JP:wght@400;500;700&family=Roboto+Mono:wght@500;700&display=swap" rel="stylesheet" />
<style>
  :root{
    --ink:#14181f;
    --ink-soft:#3a4150;
    --paper:#f4f5f3;
    --card:#ffffff;
    --line:#e4e5df;
    --blue:#1b5bd7;      /* finish-line cobalt: primary action */
    --blue-deep:#123f97;
    --good:#16a34a;      /* PR green */
    --warn:#e0641c;      /* effort orange */
    --mut:#7a8190;
    --shadow:0 1px 2px rgba(20,24,31,.06), 0 8px 24px rgba(20,24,31,.06);
  }
  *{box-sizing:border-box}
  html,body{margin:0}
  body{
    background:var(--paper);
    color:var(--ink);
    font-family:"Noto Sans JP",system-ui,sans-serif;
    -webkit-font-smoothing:antialiased;
    line-height:1.55;
    padding-bottom:env(safe-area-inset-bottom);
  }
  .mono{font-family:"Roboto Mono",ui-monospace,monospace;font-variant-numeric:tabular-nums}
  button{font-family:inherit;cursor:pointer}
  input,select,textarea{font-family:inherit;font-size:16px}
  .hidden{display:none !important}

  /* ---------- App shell ---------- */
  .wrap{max-width:560px;margin:0 auto;padding:0 16px}

  /* ---------- Auth ---------- */
  .auth{min-height:100dvh;display:flex;flex-direction:column;justify-content:center;
    background:
      repeating-linear-gradient(180deg, transparent 0 38px, rgba(20,24,31,.035) 38px 39px),
      var(--paper);
    padding:32px 0 48px;
  }
  .brand{display:flex;align-items:baseline;gap:10px}
  .brand .mark{font-family:"Anton",sans-serif;font-size:clamp(40px,12vw,64px);letter-spacing:.5px;line-height:.92;text-transform:uppercase}
  .brand .mark em{font-style:normal;color:var(--blue)}
  .lane{display:inline-block;font-family:"Roboto Mono",monospace;font-weight:700;font-size:12px;color:#fff;background:var(--ink);
    padding:3px 8px;border-radius:3px;letter-spacing:1px}
  .tagline{color:var(--ink-soft);margin:14px 2px 26px;font-size:15px}
  .card{background:var(--card);border:1px solid var(--line);border-radius:16px;box-shadow:var(--shadow)}
  .auth .card{padding:22px}
  .field{margin-bottom:14px}
  .field label{display:block;font-size:12.5px;font-weight:700;color:var(--ink-soft);margin:0 0 6px;letter-spacing:.3px}
  .field input{width:100%;padding:12px 14px;border:1.5px solid var(--line);border-radius:11px;background:#fafbf9;outline:none;transition:border-color .15s}
  .field input:focus{border-color:var(--blue);background:#fff}
  .btn{display:flex;align-items:center;justify-content:center;gap:9px;width:100%;border:none;border-radius:11px;
    padding:13px 16px;font-weight:700;font-size:15px;transition:transform .04s, filter .15s}
  .btn:active{transform:translateY(1px)}
  .btn-primary{background:var(--blue);color:#fff}
  .btn-primary:hover{filter:brightness(1.05)}
  .btn-ghost{background:#fff;color:var(--ink);border:1.5px solid var(--line)}
  .btn-google{background:#fff;color:#1f1f1f;border:1.5px solid var(--line)}
  .btn-row{display:flex;gap:10px}
  .switchline{text-align:center;margin-top:16px;font-size:13.5px;color:var(--mut)}
  .switchline button{background:none;border:none;color:var(--blue);font-weight:700;padding:0}
  .divider{display:flex;align-items:center;gap:12px;color:var(--mut);font-size:12px;margin:18px 0}
  .divider::before,.divider::after{content:"";height:1px;background:var(--line);flex:1}

  /* ---------- Top bar ---------- */
  .topbar{position:sticky;top:0;z-index:20;background:rgba(244,245,243,.86);backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line)}
  .topbar .row{display:flex;align-items:center;justify-content:space-between;height:58px}
  .topbar .mark{font-family:"Anton",sans-serif;font-size:24px;text-transform:uppercase;letter-spacing:.5px}
  .topbar .mark em{font-style:normal;color:var(--blue)}
  .userchip{display:flex;align-items:center;gap:9px}
  .avatar{width:30px;height:30px;border-radius:50%;background:var(--ink);color:#fff;display:grid;place-items:center;
    font-weight:700;font-size:13px}
  .iconbtn{background:none;border:1.5px solid var(--line);border-radius:9px;padding:7px 11px;font-size:12.5px;font-weight:700;color:var(--ink-soft)}

  /* ---------- Compose ---------- */
  .compose{margin-top:16px;padding:18px}
  .compose h2{margin:0 0 2px;font-size:16px;font-weight:700}
  .compose .sub{margin:0 0 16px;font-size:12.5px;color:var(--mut)}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .chips{display:flex;flex-wrap:wrap;gap:8px}
  .chip{border:1.5px solid var(--line);background:#fff;border-radius:999px;padding:8px 13px;font-size:13px;font-weight:500;color:var(--ink-soft)}
  .chip[aria-pressed="true"]{background:var(--ink);border-color:var(--ink);color:#fff}
  .field textarea{width:100%;padding:11px 13px;border:1.5px solid var(--line);border-radius:11px;background:#fafbf9;
    outline:none;resize:vertical;min-height:64px;line-height:1.5}
  .field textarea:focus{border-color:var(--blue);background:#fff}
  .seg{display:flex;gap:6px}
  .seg button{flex:1;border:1.5px solid var(--line);background:#fff;border-radius:9px;padding:9px 0;font-weight:700;
    font-family:"Roboto Mono",monospace;color:var(--ink-soft)}
  .seg button[aria-pressed="true"]{background:var(--blue);border-color:var(--blue);color:#fff}
  .seg.warmth button[aria-pressed="true"]{background:var(--warn);border-color:var(--warn)}
  .pubrow{display:flex;align-items:center;justify-content:space-between;margin-top:4px;
    padding:11px 13px;border:1.5px dashed var(--line);border-radius:11px}
  .pubrow .lbl{font-size:13px;font-weight:700}
  .pubrow .hint{font-size:11.5px;color:var(--mut)}
  .toggle{width:46px;height:27px;border-radius:999px;background:#d4d6cf;border:none;position:relative;transition:background .15s;flex:none}
  .toggle[aria-pressed="true"]{background:var(--good)}
  .toggle::after{content:"";position:absolute;top:3px;left:3px;width:21px;height:21px;border-radius:50%;background:#fff;transition:transform .15s}
  .toggle[aria-pressed="true"]::after{transform:translateX(19px)}

  /* ---------- Tabs ---------- */
  .tabs{display:flex;gap:6px;margin:22px 0 4px;background:#e9eae4;padding:5px;border-radius:12px}
  .tabs button{flex:1;border:none;background:none;border-radius:9px;padding:10px 0;font-weight:700;font-size:13.5px;color:var(--mut)}
  .tabs button[aria-selected="true"]{background:#fff;color:var(--ink);box-shadow:var(--shadow)}

  /* ---------- Entry cards ---------- */
  .feed{margin:14px 0 40px;display:flex;flex-direction:column;gap:12px}
  .entry{background:var(--card);border:1px solid var(--line);border-radius:14px;box-shadow:var(--shadow);
    padding:14px 16px 14px 18px;position:relative;overflow:hidden}
  .entry::before{content:"";position:absolute;left:0;top:0;bottom:0;width:5px;background:var(--blue)}
  .entry.is-rest::before{background:var(--mut)}
  .entry.is-race::before{background:var(--warn)}
  .entry .head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px}
  .entry .date{font-family:"Roboto Mono",monospace;font-weight:700;font-size:13px;color:var(--ink-soft)}
  .badge{font-size:11.5px;font-weight:700;padding:3px 9px;border-radius:999px;background:#eef1fb;color:var(--blue-deep)}
  .badge.rest{background:#f0f1ee;color:var(--mut)}
  .badge.race{background:#fdece1;color:var(--warn)}
  .who{font-size:12px;color:var(--mut);font-weight:700}
  .stats{display:flex;gap:20px;align-items:flex-end;flex-wrap:wrap}
  .stat .k{font-size:10.5px;letter-spacing:.5px;color:var(--mut);text-transform:uppercase;font-weight:700}
  .stat .v{font-family:"Roboto Mono",monospace;font-weight:700;font-size:21px;line-height:1.1}
  .stat .v small{font-size:11px;color:var(--mut);font-weight:500;margin-left:2px}
  .scores{display:flex;gap:16px;margin-top:11px}
  .scores .s{display:flex;align-items:center;gap:7px;font-size:11.5px;color:var(--mut);font-weight:700}
  .dots{display:flex;gap:3px}
  .dot{width:8px;height:8px;border-radius:50%;background:#e0e2db}
  .dot.on{background:var(--blue)}
  .dots.warm .dot.on{background:var(--warn)}
  .memo{margin:11px 0 0;font-size:13.5px;color:var(--ink-soft);white-space:pre-wrap;
    border-top:1px solid var(--line);padding-top:10px}
  .entry .actions{display:flex;gap:8px;margin-top:12px}
  .entry .actions button{background:none;border:1.5px solid var(--line);border-radius:8px;padding:6px 12px;
    font-size:12px;font-weight:700;color:var(--ink-soft)}
  .entry .actions .del{color:var(--warn);border-color:#f3d9c8}
  .empty{text-align:center;color:var(--mut);padding:48px 20px;font-size:14px}
  .empty .big{font-family:"Anton",sans-serif;font-size:30px;color:var(--line);text-transform:uppercase;margin-bottom:6px}

  /* ---------- Toast ---------- */
  #toast{position:fixed;left:50%;bottom:26px;transform:translateX(-50%) translateY(20px);
    background:var(--ink);color:#fff;padding:12px 18px;border-radius:11px;font-size:13.5px;font-weight:700;
    box-shadow:var(--shadow);opacity:0;pointer-events:none;transition:opacity .2s,transform .2s;z-index:50;max-width:90vw}
  #toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  #toast.err{background:var(--warn)}

  .spin{width:18px;height:18px;border:2.5px solid rgba(255,255,255,.45);border-top-color:#fff;border-radius:50%;
    animation:sp .7s linear infinite}
  @keyframes sp{to{transform:rotate(360deg)}}
  @media (prefers-reduced-motion: reduce){*{animation:none !important;transition:none !important}}
</style>
</head>
<body>

<!-- ===================== AUTH ===================== -->
<section id="authView" class="auth">
  <div class="wrap">
    <div class="brand">
      <span class="lane">LANE 1</span>
      <span class="mark">Run<em>Diary</em></span>
    </div>
    <p class="tagline">毎日の練習を、自分のスプリットで残す。<br>チームの記録は公開して、ひとりの記録は自分だけに。</p>

    <div class="card">
      <div class="field">
        <label for="dispname" id="nameLabel">表示名（チームに見える名前）</label>
        <input id="dispname" type="text" placeholder="例：佐々木" autocomplete="name" />
      </div>
      <div class="field">
        <label for="email">メールアドレス</label>
        <input id="email" type="email" placeholder="you@example.com" autocomplete="email" />
      </div>
      <div class="field">
        <label for="password">パスワード（6文字以上）</label>
        <input id="password" type="password" placeholder="••••••••" autocomplete="current-password" />
      </div>
      <button id="primaryAuthBtn" class="btn btn-primary">アカウントを作る</button>

      <div class="divider">または</div>
      <button id="googleBtn" class="btn btn-google">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.5 12.2c0-.7-.1-1.4-.2-2H12v3.9h5.9a5 5 0 0 1-2.2 3.3v2.7h3.5c2-1.9 3.3-4.7 3.3-7.9z"/><path fill="#34A853" d="M12 23c3 0 5.5-1 7.3-2.7l-3.5-2.7c-1 .7-2.3 1.1-3.8 1.1-2.9 0-5.4-2-6.3-4.6H2v2.8A11 11 0 0 0 12 23z"/><path fill="#FBBC05" d="M5.7 14.1a6.6 6.6 0 0 1 0-4.2V7.1H2a11 11 0 0 0 0 9.8l3.7-2.8z"/><path fill="#EA4335" d="M12 5.4c1.6 0 3.1.6 4.2 1.7l3.1-3.1A11 11 0 0 0 2 7.1l3.7 2.8C6.6 7.3 9.1 5.4 12 5.4z"/></svg>
        Googleで続ける
      </button>

      <div class="switchline" id="switchLine">
        アカウントを持ってる？<button id="switchBtn">ログイン</button>
      </div>
    </div>
  </div>
</section>

<!-- ===================== APP ===================== -->
<main id="appView" class="hidden">
  <header class="topbar">
    <div class="wrap row">
      <span class="mark">Run<em>Diary</em></span>
      <div class="userchip">
        <span class="avatar" id="avatar">?</span>
        <button class="iconbtn" id="logoutBtn">ログアウト</button>
      </div>
    </div>
  </header>

  <div class="wrap">
    <!-- compose -->
    <section class="card compose">
      <h2 id="composeTitle">今日の練習を記録</h2>
      <p class="sub" id="composeSub">距離と時間を入れると、ペース（/km）が自動で出るで。</p>

      <div class="grid2" style="margin-bottom:14px">
        <div class="field" style="margin:0">
          <label for="cDate">日付</label>
          <input id="cDate" type="date" />
        </div>
        <div class="field" style="margin:0">
          <label>公開</label>
          <div class="pubrow" style="padding:9px 12px">
            <div><div class="lbl" id="pubLbl">公開</div></div>
            <button class="toggle" id="cPublic" aria-pressed="true" aria-label="公開する"></button>
          </div>
        </div>
      </div>

      <div class="field">
        <label>メニュー</label>
        <div class="chips" id="menuChips"></div>
      </div>

      <div class="grid2">
        <div class="field">
          <label for="cDist">距離（km）</label>
          <input id="cDist" type="number" inputmode="decimal" step="0.1" min="0" placeholder="例：12.0" />
        </div>
        <div class="field">
          <label for="cTime">時間（分）</label>
          <input id="cTime" type="number" inputmode="decimal" step="0.1" min="0" placeholder="例：54.5" />
        </div>
      </div>

      <div class="grid2">
        <div class="field">
          <label>コンディション</label>
          <div class="seg" id="condSeg"></div>
        </div>
        <div class="field">
          <label>モチベーション</label>
          <div class="seg warmth" id="motiSeg"></div>
        </div>
      </div>

      <div class="field">
        <label for="cMemo">メモ</label>
        <textarea id="cMemo" placeholder="体の状態、天気、設定タイム、気づき など"></textarea>
      </div>

      <button id="saveBtn" class="btn btn-primary">記録する</button>
      <button id="cancelEditBtn" class="btn btn-ghost hidden" style="margin-top:9px">編集をやめる</button>
    </section>

    <!-- tabs -->
    <div class="tabs" role="tablist">
      <button id="tabMine" role="tab" aria-selected="true">自分の日誌</button>
      <button id="tabTeam" role="tab" aria-selected="false">チーム公開</button>
    </div>

    <div id="feed" class="feed"></div>
  </div>
</main>

<div id="toast"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
/* ====== Supabase 接続（run Project） ====== */
const SUPABASE_URL = "https://rndewdcuvewyalxvfoqi.supabase.co";
const SUPABASE_KEY = "sb_publishable_pqSIdB7XK7-Dltr_AVBhLQ_yrOhwNSN";
const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

const MENUS = ["ジョグ","ペース走","インターバル","距離走","レース","補強","休養"];

/* ====== state ====== */
let mode = "signup";        // signup | signin
let editingId = null;       // 編集中の日誌ID
let tab = "mine";
const compose = { menu:"ジョグ", cond:3, moti:3, isPublic:true };

/* ====== helpers ====== */
const $ = (id)=>document.getElementById(id);
function toast(msg, isErr){
  const t = $("toast"); t.textContent = msg; t.className = "show" + (isErr ? " err" : "");
  clearTimeout(t._h); t._h = setTimeout(()=>t.className="", 2600);
}
function todayStr(){ const d=new Date(); const o=d.getTimezoneOffset(); const l=new Date(d-o*60000); return l.toISOString().slice(0,10); }
function fmtNum(n){ return (n==null||n==="")?"—":(Math.round(Number(n)*10)/10).toString(); }
function fmtTime(min){ if(min==null) return "—"; const s=Math.round(min*60); const m=Math.floor(s/60); const ss=s%60; return m+":"+String(ss).padStart(2,"0"); }
function fmtPace(dist,time){ if(!dist||!time||dist<=0) return "—"; const sec=(time*60)/dist; const m=Math.floor(sec/60); const s=Math.round(sec%60); return m+"'"+String(s).padStart(2,"0")+'"'; }
function initial(name){ return (name||"?").trim().charAt(0).toUpperCase() || "?"; }
function esc(s){ return (s||"").replace(/[&<>"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c])); }
function menuClass(m){ return m==="休養"?"is-rest":(m==="レース"?"is-race":""); }
function badgeClass(m){ return m==="休養"?"rest":(m==="レース"?"race":""); }

/* ====== build compose controls ====== */
function buildControls(){
  $("menuChips").innerHTML = MENUS.map(m=>
    `<button class="chip" data-menu="${m}" aria-pressed="${m===compose.menu}">${m}</button>`).join("");
  const seg = (id,val,cls)=> $(id).innerHTML = [1,2,3,4,5].map(n=>
    `<button data-${cls}="${n}" aria-pressed="${n===val}">${n}</button>`).join("");
  seg("condSeg",compose.cond,"cond"); seg("motiSeg",compose.moti,"moti");
}
document.addEventListener("click",(e)=>{
  const c = e.target.closest("[data-menu]");
  if(c){ compose.menu=c.dataset.menu; buildControls(); }
  const cd = e.target.closest("[data-cond]");
  if(cd){ compose.cond=+cd.dataset.cond; buildControls(); }
  const mt = e.target.closest("[data-moti]");
  if(mt){ compose.moti=+mt.dataset.moti; buildControls(); }
});
$("cPublic").addEventListener("click",()=>{
  compose.isPublic=!compose.isPublic;
  $("cPublic").setAttribute("aria-pressed", String(compose.isPublic));
  $("pubLbl").textContent = compose.isPublic ? "公開" : "自分だけ";
});

/* ====== AUTH UI ====== */
function renderAuthMode(){
  if(mode==="signup"){
    $("primaryAuthBtn").textContent="アカウントを作る";
    $("nameLabel").parentElement.classList.remove("hidden");
    $("switchLine").innerHTML='アカウントを持ってる？<button id="switchBtn">ログイン</button>';
    $("password").autocomplete="new-password";
  }else{
    $("primaryAuthBtn").textContent="ログイン";
    $("nameLabel").parentElement.classList.add("hidden");
    $("switchLine").innerHTML='アカウント無い？<button id="switchBtn">新規登録</button>';
    $("password").autocomplete="current-password";
  }
  $("switchBtn").onclick=()=>{ mode = mode==="signup"?"signin":"signup"; renderAuthMode(); };
}
async function withSpin(btn, fn){
  const old = btn.innerHTML; btn.disabled=true; btn.innerHTML='<span class="spin"></span>';
  try{ await fn(); } finally { btn.disabled=false; btn.innerHTML=old; }
}
$("primaryAuthBtn").addEventListener("click",()=> withSpin($("primaryAuthBtn"), async ()=>{
  const email=$("email").value.trim(), pw=$("password").value, name=$("dispname").value.trim();
  if(!email||!pw){ toast("メールとパスワードを入れてな",true); return; }
  if(mode==="signup"){
    if(!name){ toast("表示名を入れてな",true); return; }
    const { error } = await sb.auth.signUp({ email, password:pw, options:{ data:{ display_name:name } } });
    if(error){ toast(error.message,true); return; }
    toast("確認メールを送ったで。承認したらログインできる");
    mode="signin"; renderAuthMode();
  }else{
    const { error } = await sb.auth.signInWithPassword({ email, password:pw });
    if(error){ toast(error.message,true); return; }
  }
}));
$("googleBtn").addEventListener("click", async ()=>{
  const { error } = await sb.auth.signInWithOAuth({ provider:"google", options:{ redirectTo: window.location.origin } });
  if(error) toast(error.message,true);
});
$("logoutBtn").addEventListener("click", async ()=>{ await sb.auth.signOut(); });

/* ====== session ====== */
let me = null;
function meName(u){ return (u.user_metadata && u.user_metadata.display_name) || (u.email? u.email.split("@")[0] : "runner"); }
async function onSession(session){
  if(session && session.user){
    me = session.user;
    $("authView").classList.add("hidden");
    $("appView").classList.remove("hidden");
    $("avatar").textContent = initial(meName(me));
    await loadFeed();
  }else{
    me = null;
    $("appView").classList.add("hidden");
    $("authView").classList.remove("hidden");
  }
}
sb.auth.onAuthStateChange((_e, session)=>onSession(session));

/* ====== save / edit ====== */
function readForm(){
  const dist = $("cDist").value==="" ? null : Number($("cDist").value);
  const time = $("cTime").value==="" ? null : Number($("cTime").value);
  return {
    entry_date: $("cDate").value || todayStr(),
    user_name: meName(me),
    menu_type: compose.menu,
    distance_km: dist,
    time_min: time,
    condition_score: compose.cond,
    motivation_score: compose.moti,
    memo: $("cMemo").value.trim() || null,
    is_public: compose.isPublic
  };
}
function resetForm(){
  editingId=null;
  $("cDate").value=todayStr(); $("cDist").value=""; $("cTime").value=""; $("cMemo").value="";
  compose.menu="ジョグ"; compose.cond=3; compose.moti=3; compose.isPublic=true;
  $("cPublic").setAttribute("aria-pressed","true"); $("pubLbl").textContent="公開";
  buildControls();
  $("composeTitle").textContent="今日の練習を記録";
  $("saveBtn").textContent="記録する";
  $("cancelEditBtn").classList.add("hidden");
}
$("cancelEditBtn").addEventListener("click", resetForm);
$("saveBtn").addEventListener("click",()=> withSpin($("saveBtn"), async ()=>{
  const row = readForm();
  let error;
  if(editingId){
    ({ error } = await sb.from("diary_entries").update(row).eq("id", editingId));
  }else{
    ({ error } = await sb.from("diary_entries").insert({ ...row, user_id: me.id }));
  }
  if(error){ toast(error.message,true); return; }
  toast(editingId? "更新したで" : "記録したで💪");
  resetForm(); await loadFeed();
}));

/* ====== feed ====== */
$("tabMine").addEventListener("click",()=>setTab("mine"));
$("tabTeam").addEventListener("click",()=>setTab("team"));
function setTab(t){
  tab=t;
  $("tabMine").setAttribute("aria-selected", String(t==="mine"));
  $("tabTeam").setAttribute("aria-selected", String(t==="team"));
  loadFeed();
}
async function loadFeed(){
  $("feed").innerHTML = '<div class="empty">読み込み中…</div>';
  let q = sb.from("diary_entries").select("*");
  if(tab==="mine"){ q = q.eq("user_id", me.id); }
  else { q = q.eq("is_public", true); }
  q = q.order("entry_date",{ascending:false}).order("created_at",{ascending:false}).limit(200);
  const { data, error } = await q;
  if(error){ $("feed").innerHTML=`<div class="empty">読み込めへんかった：${esc(error.message)}</div>`; return; }
  renderFeed(data||[]);
}
function dotRow(score, warm){
  let h='<div class="dots'+(warm?" warm":"")+'">';
  for(let i=1;i<=5;i++) h+=`<span class="dot${i<=score?" on":""}"></span>`;
  return h+"</div>";
}
function renderFeed(rows){
  if(!rows.length){
    $("feed").innerHTML = tab==="mine"
      ? '<div class="empty"><div class="big">No splits yet</div>まだ記録がないで。<br>上のフォームから今日の練習をつけよう。</div>'
      : '<div class="empty"><div class="big">Quiet track</div>公開された練習はまだ無いで。</div>';
    return;
  }
  $("feed").innerHTML = rows.map(r=>{
    const mine = r.user_id===me.id;
    const isRest = r.menu_type==="休養";
    return `
    <article class="entry ${menuClass(r.menu_type)}">
      <div class="head">
        <span class="date mono">${esc(r.entry_date)}</span>
        <span class="badge ${badgeClass(r.menu_type)}">${esc(r.menu_type)}</span>
      </div>
      ${tab==="team" ? `<div class="who">@ ${esc(r.user_name||"runner")}</div>` : ""}
      ${ isRest ? "" : `
      <div class="stats">
        <div class="stat"><div class="k">距離</div><div class="v mono">${fmtNum(r.distance_km)}<small>km</small></div></div>
        <div class="stat"><div class="k">時間</div><div class="v mono">${fmtTime(r.time_min)}</div></div>
        <div class="stat"><div class="k">ペース</div><div class="v mono">${fmtPace(r.distance_km,r.time_min)}<small>/km</small></div></div>
      </div>`}
      <div class="scores">
        <div class="s">調子 ${dotRow(r.condition_score||0,false)}</div>
        <div class="s">気持ち ${dotRow(r.motivation_score||0,true)}</div>
      </div>
      ${ r.memo ? `<p class="memo">${esc(r.memo)}</p>` : "" }
      ${ mine ? `<div class="actions">
        <button class="edit" data-id="${r.id}">編集</button>
        <button class="del" data-id="${r.id}">削除</button>
      </div>`:""}
    </article>`;
  }).join("");

  $("feed").querySelectorAll(".edit").forEach(b=> b.onclick=()=>startEdit(rows.find(x=>x.id===b.dataset.id)));
  $("feed").querySelectorAll(".del").forEach(b=> b.onclick=()=>doDelete(b.dataset.id));
}
function startEdit(r){
  editingId=r.id;
  $("cDate").value=r.entry_date;
  $("cDist").value=r.distance_km ?? "";
  $("cTime").value=r.time_min ?? "";
  $("cMemo").value=r.memo ?? "";
  compose.menu=r.menu_type||"ジョグ";
  compose.cond=r.condition_score||3;
  compose.moti=r.motivation_score||3;
  compose.isPublic = r.is_public!==false;
  $("cPublic").setAttribute("aria-pressed", String(compose.isPublic));
  $("pubLbl").textContent = compose.isPublic?"公開":"自分だけ";
  buildControls();
  $("composeTitle").textContent="記録を編集";
  $("saveBtn").textContent="更新する";
  $("cancelEditBtn").classList.remove("hidden");
  window.scrollTo({top:0,behavior:"smooth"});
}
async function doDelete(id){
  if(!confirm("この記録を削除する？")) return;
  const { error } = await sb.from("diary_entries").delete().eq("id", id);
  if(error){ toast(error.message,true); return; }
  toast("削除したで"); if(editingId===id) resetForm(); await loadFeed();
}

/* ====== init ====== */
buildControls(); renderAuthMode(); resetForm();
sb.auth.getSession().then(({data})=>onSession(data.session));
</script>
</body>
</html>
